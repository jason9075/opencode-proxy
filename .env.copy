# Provider: openai | gemini | copilot
PROVIDER=openai

# Server settings
PORT=8888
LOG_DIR=./logs
DATABASE_PATH=./data/opencode-proxy.db
REQUEST_TIMEOUT=5m

# OpenAI settings
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com

# Gemini settings
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# GitHub Copilot settings (OpenAI-compatible)
COPILOT_API_KEY=
COPILOT_BASE_URL=https://api.githubcopilot.com
